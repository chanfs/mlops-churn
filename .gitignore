.git/
.gitignore
.gitattributes

# DVC (track .dvc files, ignore cache)
.dvc/cache/
.dvc/tmp/

# Data (track .dvc meta files, ignore actual data)
data/raw/
!data/raw/.gitkeep
data/processed/
!data/processed/.gitkeep
data/external/
!data/external/.gitkeep

# Models (track model.pkl for deployment, ignore others)
models/*
!models/model.pkl
!models/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/

# IDE
.idea/
.vscode/
*.swp
*.swo

# MLflow
mlruns/
mlflow.db

# Logs
*.log

# Environment
.env
.env.local

# Testing
.coverage
htmlcov/
.pytest_cache/

